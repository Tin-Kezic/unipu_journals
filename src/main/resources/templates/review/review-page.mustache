<dialog id="end-round-dialog" closedby="any">
    <form id="end-round-dialog-form" style="display: flex; flex-direction: column; gap: 0.5rem;">
        <div style="display: flex; gap: 0.5rem;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <input type="radio" id="editor-accept" name="editor-recommendation" value="ACCEPT" style="display: none;">
                <label for="editor-accept" class="sidebar-button" style="display: flex; justify-content: center;">Accept</label>

                <input type="radio" id="editor-minor" name="editor-recommendation" value="MINOR" style="display: none;">
                <label for="editor-minor" class="sidebar-button" style="display: flex; justify-content: center;">Minor</label>

                <input type="radio" id="editor-major" name="editor-recommendation" value="MAJOR" style="display: none;">
                <label for="editor-major" class="sidebar-button" style="display: flex; justify-content: center;">Major</label>

                <input type="radio" id="editor-reject" name="editor-recommendation" value="REJECT" style="display: none;">
                <label for="editor-reject" class="sidebar-button" style="display: flex; justify-content: center;">Reject</label>
            </div>
            <div class="text-field" style="margin: 0;">
                <label for="end-round-dialog-textarea">editor's comment</label>
                <textarea id="end-round-dialog-textarea" name="end-round-dialog-textarea" type="text" style="width: 25rem; height: 12.5rem; padding: 1rem; font-size: medium;"></textarea>
            </div>
        </div>
        <div style="display: flex; justify-content: space-between">
            <button id="end-round-dialog-negative" type="button" class="m3-button outlined-button">Cancel</button>
            <button class="m3-button primary-button" style="margin-left: 1rem; padding-inline: 1.7rem;">End round</button>
        </div>
    </form>
</dialog>
<script>
    const endRoundDialog = document.getElementById('end-round-dialog');
    document.getElementById('end-round').addEventListener('click', () => endRoundDialog.showModal());
    document.getElementById('end-round-dialog-negative').addEventListener('click', () => endRoundDialog.close());
    document.getElementById('end-round-dialog-form').addEventListener('submit', async (event) => {
        event.preventDefault();
        const recommendation = document.querySelector('input[name="editor-recommendation"]:checked').value;
        const editorComment = document.getElementById('end-round-dialog-textarea').value;
        const response = await fetch(`/api/manuscripts/{{manuscriptId}}/review-rounds/end`, { method: 'POST', body: new URLSearchParams({ recommendation, editorComment })});
        if(!response.ok) { alert(await response.text()); return; }
        if('{{type}}' == 'EIC' && recommendation == 'ACCEPT') window.location = `/manuscripts/{{manuscriptId}}/technical-processing`;
        else history.back();
    });
</script>
<style>
    .content {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem;
    }
    .container {
        width: auto !important;
        height: auto !important;
        margin-bottom: 1rem;
    }
    aside .container {
        width: 100%;
        margin-bottom: 0.5rem;
        font-weight: 100;
    }
    .container:hover {
        background-color: white;
    }
    .rating-table td:first-child { /* td is table data */
        text-align: right;
        padding-right: 1rem;
    }
    .rating-table td, .rating-table th {
        padding: 0.1rem 0.4rem;
    }
    .rating-table th {
        padding-left: 0.8rem;
        text-align: center;
    }
    .pale-yellow-checkbox-button .checkbox {
        width: fit-content;
        white-space: nowrap;
        padding: 0.2rem 0.5rem;
    }
    .download-button:hover {
        color: var(--primary) !important;
    }
    @media screen and (max-width: 1300px) {
        .content {
            display: flex;
            flex-direction: column;
        }
        .container .article {
            width: 96vw !important;
            max-width: 100vw !important;
        }
        .recommendations-description {
            width: 96vw !important;
            max-width: 100vw !important;
        }
        .recommendations-tables {
            flex-direction: column !important;
            gap: 1rem !important;
        }
        .rating-table-container {
            width: 100% !important;
            min-width: auto !important;
            max-width: 27rem !important;
        }
        .check-question {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 0.5rem !important;
        }
        .check-question p {
            white-space: normal !important;
            max-width: 100% !important;
        }
        .pale-yellow-checkbox-button {
            align-self: flex-start !important;
        }
        .recommendations-tables .container:last-child {
            width: 100% !important;
            max-width: 87vw !important;
            min-width: auto !important;
        }
        .container .article-box {
            order: 1;
            width: 96vw !important;
            max-width: 100vw !important;
            margin-bottom: 1rem;
        }
    }
</style>
</html>